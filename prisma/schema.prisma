generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  name         String?
  username     String        @unique
  passwordHash String
  role         String        @default("MEMBER") // "ADMIN" or "MEMBER"
  memberSerial Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  premiums     Premium[]
  loans        Loan[]
  loanRequests LoanRequest[]
}

model Premium {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  amount    Float
  datePaid  DateTime
  user      User     @relation(fields: [userId], references: [id])
}

model Loan {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  customId         String        @unique
  userId           String        @db.ObjectId
  principalAmount  Float
  interestRate     Float
  startDate        DateTime
  status           String        @default("ACTIVE") // "ACTIVE", "SETTLED", "FORECLOSED"
  foreclosureMonth String?       // e.g., "2023-11"
  settlementAmount Float?
  user             User          @relation(fields: [userId], references: [id])
  installments     Installment[]
}

model Installment {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  loanId       String    @db.ObjectId
  monthYear    String    // e.g., "2023-10"
  amountDue    Float
  principalDue Float     @default(0)
  interestDue  Float     @default(0)
  dueDate      DateTime
  amountPaid   Float     @default(0)
  interestPaid Float     @default(0)
  paidDate     DateTime?
  status       String    @default("PENDING") // "PENDING" or "PAID"
  loan         Loan      @relation(fields: [loanId], references: [id])
}

model Expenditure {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  amount        Float
  date          DateTime @default(now())
  monthYear     String   // e.g., "2023-10"
  remarks       String?
  isChitPayment Boolean  @default(false)
}

model Setting {
  id             String @id @default(auto()) @map("_id") @db.ObjectId
  monthlyPremium Float  @default(0)
}

model LoanRequest {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  amount    Float
  monthYear String
  durationMonths Int
  priority  String
  remarks   String?
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
